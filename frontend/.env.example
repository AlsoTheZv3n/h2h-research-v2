# The SPA calls same-origin /api/*; the Vite proxy strips the prefix and forwards.
# A deployment can point this at a real host instead.
VITE_API_BASE_URL=/api

# Where the dev proxy sends /api. Note this machine's 8000/8080 are held by WSL.
VITE_API_PROXY_TARGET=http://localhost:8081

# Dev server port. 5173 is taken by a WSL listener on some machines.
VITE_PORT=5173

