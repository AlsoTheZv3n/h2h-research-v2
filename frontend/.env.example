# The SPA calls same-origin /api/*; the dev proxy strips the prefix and forwards.
# A deployment can point this at a real host instead.
VITE_API_BASE_URL=/api

# Where pnpm dev sends /api. Defaults to what compose publishes.
VITE_API_PROXY_TARGET=http://localhost:8080

# Dev server port. Override if something else already owns 5173 -- note that WSL
# mirrors its listeners onto Windows' localhost, so a clash answers with someone
# else's server rather than failing to bind.
VITE_PORT=5173
