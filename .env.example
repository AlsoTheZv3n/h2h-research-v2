# Copy to .env and adjust. .env is gitignored -- this repo is public, keep keys out of it.

ENVIRONMENT=development
LOG_LEVEL=INFO

# Host ports for `docker compose`. Override when something else already owns one --
# note that WSL forwards its listeners onto Windows' localhost, so a clash shows up
# as a reply from someone else's server, not as a bind error. Container ports never move.
API_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379

# If you change API_PORT, change this too -- they are two halves of one setting and
# nothing keeps them in sync. `pnpm dev` proxies /api here, and the default is 8080
# because that is API_PORT's default. Set API_PORT=8081 and forget this, and the dev
# server proxies to whatever else happens to own 8080; on the machine this was
# written on that was an unrelated Java service, which answered every API call with a
# JSON error and made the app look broken in a way that pointed nowhere near the
# cause. It cost an hour. Only `pnpm dev` reads this -- `docker compose up` uses the
# compose network and is unaffected.
VITE_API_PROXY_TARGET=http://localhost:8080

# Compose sets these to the service names; these defaults suit a local run.
DATABASE_URL=postgresql+asyncpg://h2h:h2h@localhost:5432/h2h
REDIS_URL=redis://localhost:6379/0

CACHE_TTL_SECONDS=3600

# The refresh cron (the `refresh` compose service) fills drugs ahead of demand and
# re-enriches stale ones. This is how long it sleeps between passes (daily by default),
# and how old a brief may get before a pass re-enriches it. Long on purpose -- source
# facts move on the order of weeks, so a tighter loop is cost without benefit.
REFRESH_INTERVAL_SECONDS=86400
FRESHNESS_DAYS=30

# Optional. Only raises PubMed (E-utilities) rate limits, from 3/s to 10/s.
# https://www.ncbi.nlm.nih.gov/account/ -> Settings -> API Key Management
NCBI_API_KEY=

# NCBI asks every E-utilities client to identify itself and to give them a way to
# reach whoever is running it. Both have working defaults, so leaving this alone is
# fine for a local look -- but if you point this at PubMed in any sustained way, put
# a real address here. It is the difference between NCBI mailing you about a
# misbehaving script and NCBI blocking your IP without a word.
NCBI_TOOL=h2h-research
NCBI_EMAIL=

# Host port for the UI. docker compose up then opens on this.
FRONTEND_PORT=5173

# --- The chat. The only part of this project that needs a key. ---
#
# Browsing, the sourced briefs, and the literature search all work without either of
# these: the embedding model runs locally inside the API container. Only composing
# an answer needs a model, and with neither set the ask box says so plainly instead
# of breaking -- that is a designed state, not a failure.
#
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
CHAT_MODEL=claude-haiku-4-5

# Keyless alternative: any Ollama-served model. Used only when ANTHROPIC_API_KEY is
# empty. From inside compose the host is not localhost -- use
# http://host.docker.internal:11434 (Docker Desktop) or your host's LAN address.
# Left blank on purpose: a default pointing at a port with nothing on it turns
# "no model configured", which the UI states honestly, into a connection error that
# reads like our bug.
OLLAMA_URL=
OLLAMA_MODEL=llama3.1:8b

