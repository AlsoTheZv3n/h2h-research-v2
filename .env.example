# Copy to .env and adjust. .env is gitignored -- this repo is public, keep keys out of it.

ENVIRONMENT=development
LOG_LEVEL=INFO

# Compose sets these to the service names; these defaults suit a local run.
DATABASE_URL=postgresql+asyncpg://h2h:h2h@localhost:5432/h2h
REDIS_URL=redis://localhost:6379/0

CACHE_TTL_SECONDS=3600

# Optional. Only raises PubMed (E-utilities) rate limits; nothing needs it.
# https://www.ncbi.nlm.nih.gov/account/ -> Settings -> API Key Management
NCBI_API_KEY=
